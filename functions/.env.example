# Copy to `.env` for local emulator only. Production uses Firebase secrets / Functions config.

# --- Firebase admin (local emulator) ---
HAL_FIREBASE_PROJECT_ID=
HAL_FIREBASE_CLIENT_EMAIL=
HAL_FIREBASE_PRIVATE_KEY=

# --- Odds API (the-odds-api.com) ---
ODDS_API_KEY=
ODDS_API_BOOKMAKERS=fanduel,draftkings,prizepicks,underdog
ODDS_API_REGIONS=
ODDS_API_PLAN_MODE=paid
ODDS_API_MONTHLY_TARGET_CALLS=5000000
ODDS_PROP_MARKET_TIER=full
ODDS_API_EVENT_PROP_LIMIT=120
ODDS_API_PROP_CONCURRENCY=6
ODDS_API_DAILY_BURST_MULTIPLIER=1.35
# From this UTC calendar day (1–31), allow full daily allowance immediately (no intraday ramp).
ODDS_API_FLAT_PACE_FROM_DAY=20
ENFORCE_BUDGET_GUARD=1
PROPS_WINDOW_DAYS_DEFAULT=3

# --- RapidAPI fallback (optional) ---
RAPIDAPI_KEY=
RAPIDAPI_ODDS_HOST=
RAPIDAPI_ODDS_BASE_URL=

# --- Stripe (use firebase functions:secrets:set in prod) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CORE_MONTHLY=
STRIPE_PRICE_BRUCE_PICKS_MONTHLY=
STRIPE_PRICE_BRUCE_PREMIUM_MONTHLY=
STRIPE_PRICE_CURATOR_GIAP=
STRIPE_PRICE_CURATOR_BRUCE=
STRIPE_PRICE_ALL_CURATORS=
# Aliases (optional; billing.js accepts these too):
# STRIPE_PRICE_GIAP= STRIPE_PRICE_CURATORS_ALL=

# --- Owner + curator logins (emails must exist in Firebase Auth) ---
# Two lanes only: Bruce (owner / main admin) + Giap (co-curator). See docs/CURATOR_ACCOUNTS.md.
OWNER_EMAIL=brucebrian50@gmail.com
CURATOR_GIAP_EMAIL=giap.social1@gmail.com
# Optional — only if Bruce’s picks lane should use a different email than OWNER_EMAIL:
CURATOR_BRUCE_EMAIL=

# Ops desk PIN (header X-Ops-Pin). Production: firebase functions:secrets:set OPS_DASHBOARD_PIN
OPS_DASHBOARD_PIN=2012
# Brute-force protection (optional): max failures per IP per window (default 12 / 15 min)
# OPS_AUTH_MAX_FAILURES=12
# OPS_AUTH_WINDOW_MS=900000

# --- Ops AI narrative (optional) ---
OPENAI_API_KEY=
OPENAI_OPS_MODEL=gpt-4o-mini

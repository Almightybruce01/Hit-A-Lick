{
  "functions": {
    "source": "functions"
  },
  "emulators": {
    "functions": {
      "port": 5001
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  },
  "hosting": {
    "public": "site",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=120" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/post-picks",
        "destination": "/picks-hub.html"
      },
      {
        "source": "/picks-hub",
        "destination": "/picks-hub.html"
      },
      {
        "source": "/ops",
        "destination": "/ops-dashboard.html"
      },
      {
        "source": "/api/**",
        "function": "api"
      }
    ]
  }
}
